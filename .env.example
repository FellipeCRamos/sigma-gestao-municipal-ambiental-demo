# Template de ambiente (demo academico). O setup do backend usa backend/.env.example.
# Copie para .env e ajuste ao seu ambiente local. Valores ficticios e demonstrativos.
NODE_ENV=development
PORT=3001
APP_PUBLIC_URL=http://127.0.0.1:5173

# Banco PostgreSQL local
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=usuario_demo
DB_PASSWORD=demo_pass
DB_NAME=sigma_demo

# Segredo JWT - use um valor aleatorio com pelo menos 32 caracteres
JWT_SECRET=chave_demo_substituir_localmente_com_no_minimo_32_caracteres

# CORS - origens permitidas separadas por virgula
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
